bolo "=== SMART AI GAME ==="

mavi secret = 73

mavi low = 1
mavi high = 100

mavi guess = 0
mavi steps = 0

jabtak low <= high {

    guess = (low + high) / 2

    bolo "AI Guess:"
    bolo guess

    steps = steps + 1

    agar guess == secret {
        bolo "AI WIN"
        bolo "Steps:"
        bolo steps
        rukja
    }

    agar guess < secret {
        low = low + 1
    } warna {
        high = high - 1
    }

    agar steps > 50 {
        bolo "SAFE EXIT"
        rukja
    }
}
