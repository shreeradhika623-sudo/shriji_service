bolo "=== AI GUESS PRO ==="

mavi low = 1
mavi high = 100
mavi secret = 73
mavi guess = 0
mavi steps = 0

jabtak guess != secret {

    guess = (low + high) / 2

    bolo "AI Guess:"
    bolo guess

    agar guess < secret {
        low = guess + 1
    } warna {
        agar guess > secret {
            high = guess - 1
        } warna {
            bolo "AI WIN"
        }
    }

    steps = steps + 1
}

bolo "Steps:"
bolo steps
