# ===== BUBU ABKARI VIBHAG ENGINE =====

# 🔹 RAW INPUT
mavi expected = 12500
mavi actual = 10700
mavi shops = 674

# 🔹 CORE ENGINE
mavi gap = expected - actual
mavi leakage_percent = (gap * 100) / expected

mavi monthly_loss = gap / 12
mavi daily_loss = gap / 365
mavi hourly_loss = daily_loss / 24

mavi per_shop = actual / shops

# 🔹 MODEL CHECK
mavi simulated = (actual * 5) / 100

# 🔹 DECISION ENGINE
mavi risk = 0
agar leakage_percent > 10 {
    risk = 2
} warna {
    agar leakage_percent > 5 {
        risk = 1
    } warna {
        risk = 0
    }
}

mavi structural = 0
agar gap > simulated {
    structural = 1
}

# =========================
# 📊 REPORT 1 (PURE DATA)
# =========================

bolo "----- REPORT 1 -----"

bolo gap
bolo leakage_percent
bolo monthly_loss
bolo daily_loss
bolo hourly_loss
bolo per_shop
bolo simulated

# =========================
# 📄 REPORT 2 (INTERPRETATION)
# =========================

bolo "----- REPORT 2 -----"

agar risk == 2 {

    agar structural == 1 {
        bolo "HIGH RISK"
        bolo "MISMATCH"
    } warna {
        bolo "HIGH LOSS"
    }

} warna {

    agar risk == 1 {
        bolo "MODERATE"
    } warna {
        bolo "LOW"
    }
}

agar gap > 1000 {
    bolo "CHECK REQUIRED"
} warna {
    bolo "NORMAL"
}

# =========================
# 🚨 SIGNAL LAYER
# =========================

bolo "----- SIGNAL -----"

agar risk == 2 {
    bolo "PATTERN BREAK"
} warna {
    bolo "WITHIN MODEL"
}

bolo "----- CONFIDENCE -----"

agar structural == 1 {
    bolo "LOW CONFIDENCE IN DATA CONSISTENCY"
} warna {
    bolo "DATA WITHIN EXPECTED RANGE"
}

# =========================
# 🧠 MESSAGE
# =========================

bolo "----- MESSAGE -----"

bolo "Code likhna shuruat hai, samajh banana asli kaam hai"
bolo "Har number kuch bolta hai, bas sunna aana chahiye"

bolo "Jahan farq badhta hai, wahan sawal uthte hain"
bolo "System tab tak strong hai jab tak data ignore nahi hota"

bolo "===== END ====="
