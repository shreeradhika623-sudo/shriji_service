mavi balance = 1000

mavi rate = 10

mavi withdraw = 150

mavi year = 1

jabtak (year <= 100000) {

    mavi interest = (balance * rate) / 100

    balance = balance + interest

    balance = balance - withdraw

    bolo balance

    agar (balance < 500) {

        bolo "LOW BALANCE WARNING"

    }

    agar (balance <= 0) {

        bolo "ACCOUNT EMPTY"

    }

    year = year + 1

}
